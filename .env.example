# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth gate (single-user app — only this email may log in)
ALLOWED_EMAIL=you@example.com

# AI providers (used in later phases)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Site URL (used as redirect base for magic links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Briefing coach (/briefing): OPTIONAL. Wind + currents come from Open-Meteo
# (free, no key). If set, wind is taken from the Windy Point Forecast API
# instead. Windy's point API does not provide currents — those stay Open-Meteo.
# Get a free key at https://api.windy.com/keys
WINDY_API_KEY=
